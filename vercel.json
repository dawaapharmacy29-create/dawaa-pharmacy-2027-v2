{
  "framework": "vite",
  "installCommand": "rm -rf node_modules && npm install -g yarn@1.22.22 && yarn install --ignore-engines --non-interactive --network-timeout 600000",
  "buildCommand": "yarn build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
